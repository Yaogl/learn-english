{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@/*": ["assets/scripts/*"]
    },
    "skipLibCheck": true,
    "declaration": true
  },
  "include": ["assets/scripts/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
